import random

# ASCII art for the hangman stages
HANGMAN_PICS = [
    """
     +---+
         |
         |
         |
        ===""",
    """
     +---+
     O   |
         |
         |
        ===""",
    """
     +---+
     O   |
     |   |
         |
        ===""",
    """
     +---+
     O   |
    /|   |
         |
        ===""",
    """
     +---+
     O   |
    /|\\  |
         |
        ===""",
    """
     +---+
     O   |
    /|\\  |
    /    |
        ===""",
    """
     +---+
     O   |
    /|\\  |
    / \\  |
        ===""",
]

# Word bank for the game
WORDS = [
    "python",
    "developer",
    "algorithm",
    "computer",
    "software",
    "variable",
    "database",
    "interface",
]


def play_hangman():
    # Setup game variables
    secret_word = random.choice(WORDS).lower()
    guessed_letters = set()
    incorrect_guesses = 0
    max_turns = len(HANGMAN_PICS) - 1

    print("Welcome to Hangman!")

    while incorrect_guesses < max_turns:
        print(HANGMAN_PICS[incorrect_guesses])

        # Display the current state of the word (e.g., p _ t h _ n)
        display_word = [
            letter if letter in guessed_letters else "_" for letter in secret_word
        ]
        print(f"Word: {' '.join(display_word)}")
        print(f"Guessed letters: {', '.join(sorted(guessed_letters))}")

        # Check if the player has won
        if "_" not in display_word:
            print(
                f"\n🎉 Congratulations! You guessed the word: '{secret_word}'!"
            )
            break

        # Get player input
        guess = input("Guess a letter: ").lower().strip()

        # Validate input
        if len(guess) != 1 or not guess.isalpha():
            print("❌ Invalid input. Please enter a single letter.")
            continue
        if guess in guessed_letters:
            print(f"⚠️ You already guessed '{guess}'. Try another letter.")
            continue

        # Process the guess
        guessed_letters.add(guess)

        if guess in secret_word:
            print(f"✅ Good job! '{guess}' is in the word.")
        else:
            print(f"❌ Oops! '{guess}' is not in the word.")
            incorrect_guesses += 1

    # Check if the player lost
    if incorrect_guesses == max_turns:
        print(HANGMAN_PICS[incorrect_guesses])
        print("\n💀 Game Over! You ran out of tries.")
        print(f"The secret word was: '{secret_word}'")


if __name__ == "__main__":
    play_hangman()
